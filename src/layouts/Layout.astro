---
import '../styles/global.css';
import { languages, type Lang, useTranslations, getLocalizedPath } from '../i18n';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  image?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  tags?: string[];
}

const {
  title,
  description = 'Blog técnico de Vinicius Buscacio — Cloud, IA, Microsoft Teams',
  lang = 'pt',
  image,
  type = 'website',
  publishedDate,
  tags = [],
} = Astro.props;

const t = useTranslations(lang);
const currentPath = Astro.url.pathname.replace(`/${lang}`, '') || '/';
const canonicalUrl = `https://viniciusbuscacio.blog${Astro.url.pathname}`;
const ogImage = image || 'https://viniciusbuscacio.blog/og-default.png';
const fullTitle = `${title} | Vinicius Buscacio`;

// GA4 Measurement ID — replace with real one when created
const GA_ID = 'G-M5LPZG24SP';
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}
    <meta name="author" content="Vinicius Buscacio" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Vinicius Buscacio" />
    <meta property="og:locale" content={lang === 'pt' ? 'pt_BR' : lang === 'es' ? 'es_ES' : 'en_US'} />
    {publishedDate && <meta property="article:published_time" content={publishedDate.toISOString()} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Alternate languages -->
    {Object.keys(languages).map((code) => (
      <link rel="alternate" hreflang={code} href={`https://viniciusbuscacio.blog${getLocalizedPath(currentPath, code as Lang)}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`https://viniciusbuscacio.blog/pt${currentPath}`} />

    <!-- Google Analytics 4 -->
    {GA_ID !== 'G-XXXXXXXXXX' && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline define:vars={{ GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA_ID);
        </script>
      </>
    )}

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(
      type === 'article' ? {
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "author": { "@type": "Person", "name": "Vinicius Buscacio" },
        "datePublished": publishedDate?.toISOString(),
        "image": ogImage,
        "url": canonicalUrl,
      } : {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Vinicius Buscacio",
        "url": "https://viniciusbuscacio.blog",
        "description": description,
        "author": { "@type": "Person", "name": "Vinicius Buscacio" },
      }
    )} />

    <script is:inline>
      if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="bg-white dark:bg-black text-gray-900 dark:text-gray-200 min-h-screen flex flex-col transition-colors">
    <!-- Header -->
    <header class="border-b border-gray-200 dark:border-gray-800 sticky top-0 bg-white/80 dark:bg-black/80 backdrop-blur-sm z-50">
      <nav class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href={getLocalizedPath('/', lang)} class="text-xl font-bold text-black dark:text-white hover:opacity-80 transition">
          Vinicius Buscacio
        </a>
        
        <div class="flex items-center gap-6">
          <!-- Desktop nav -->
          <div class="hidden sm:flex items-center gap-4 text-sm">
            <a href={getLocalizedPath('/', lang)} class="text-gray-600 dark:text-gray-400 hover:text-black dark:hover:text-white transition">{t('nav.home')}</a>
            <a href={getLocalizedPath('/about', lang)} class="text-gray-600 dark:text-gray-400 hover:text-black dark:hover:text-white transition">{t('nav.about')}</a>
            <a href={getLocalizedPath('/tags', lang)} class="text-gray-600 dark:text-gray-400 hover:text-black dark:hover:text-white transition">{t('nav.tags')}</a>
          </div>

          <!-- Mobile hamburger -->
          <button
            id="mobile-menu-btn"
            class="sm:hidden p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-900 transition"
            aria-label="Menu"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>

          <!-- Language Switcher -->
          <div class="flex items-center gap-1 text-xs">
            {Object.entries(languages).map(([code, name]) => (
              <a
                href={getLocalizedPath(currentPath, code as Lang)}
                class:list={[
                  'px-2 py-1 rounded transition',
                  code === lang
                    ? 'bg-black text-white dark:bg-white dark:text-black'
                    : 'text-gray-500 hover:text-black dark:hover:text-white',
                ]}
              >
                {code.toUpperCase()}
              </a>
            ))}
          </div>

          <!-- Theme Toggle -->
          <button
            id="theme-toggle"
            class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-900 transition"
            aria-label="Toggle dark mode"
          >
            <svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" />
            </svg>
            <svg class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20">
              <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
            </svg>
          </button>
        </div>
      </nav>
    </header>

    <!-- Main -->
    <main class="flex-1 max-w-5xl mx-auto px-4 py-8 w-full">
      <slot />
    </main>

    <!-- Mobile menu (hidden by default) -->
    <div id="mobile-menu" class="hidden sm:hidden border-b border-gray-200 dark:border-gray-800 bg-white dark:bg-black">
      <div class="max-w-5xl mx-auto px-4 py-3 flex flex-col gap-3 text-sm">
        <a href={getLocalizedPath('/', lang)} class="text-gray-600 dark:text-gray-400 hover:text-black dark:hover:text-white transition py-1">{t('nav.home')}</a>
        <a href={getLocalizedPath('/about', lang)} class="text-gray-600 dark:text-gray-400 hover:text-black dark:hover:text-white transition py-1">{t('nav.about')}</a>
        <a href={getLocalizedPath('/tags', lang)} class="text-gray-600 dark:text-gray-400 hover:text-black dark:hover:text-white transition py-1">{t('nav.tags')}</a>
      </div>
    </div>

    <!-- Footer -->
    <footer class="border-t border-gray-200 dark:border-gray-800 py-6">
      <div class="max-w-5xl mx-auto px-4 text-center text-sm text-gray-500 dark:text-gray-500 space-y-2">
        <div class="flex justify-center gap-4">
          <a href={getLocalizedPath('/about', lang)} class="hover:text-black dark:hover:text-white transition">{t('nav.about')}</a>
          <span>·</span>
          <a href="https://github.com/viniciusbuscacio" class="hover:text-black dark:hover:text-white transition" target="_blank" rel="noopener">GitHub</a>
          <span>·</span>
          <a href="https://www.linkedin.com/in/vinicius-buscacio/" class="hover:text-black dark:hover:text-white transition" target="_blank" rel="noopener">LinkedIn</a>
        </div>
        <p>{t('footer.madeWith')} <a href="https://astro.build" class="text-black dark:text-white hover:underline">Astro</a> {t('footer.by')}</p>
      </div>
    </footer>

    <script is:inline>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });

      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        const menu = document.getElementById('mobile-menu');
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>

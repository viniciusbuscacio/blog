---
import '../styles/global.css';
import { languages, type Lang, useTranslations, getLocalizedPath } from '../i18n';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  image?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  tags?: string[];
}

const {
  title,
  description = 'Blog técnico de Vinicius Buscacio — Cloud, IA, Microsoft Teams',
  lang = 'pt',
  image,
  type = 'website',
  publishedDate,
  tags = [],
} = Astro.props;

const t = useTranslations(lang);
const currentPath = Astro.url.pathname.replace(`/${lang}`, '') || '/';
const canonicalUrl = `https://viniciusbuscacio.blog${Astro.url.pathname}`;
const ogImage = image || 'https://viniciusbuscacio.blog/og-default.png';
const fullTitle = `${title} | Vinicius Buscacio`;

// GA4 Measurement ID — replace with real one when created
const GA_ID = 'G-M5LPZG24SP';
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}
    <meta name="author" content="Vinicius Buscacio" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Vinicius Buscacio" />
    <meta property="og:locale" content={lang === 'pt' ? 'pt_BR' : lang === 'es' ? 'es_ES' : 'en_US'} />
    {publishedDate && <meta property="article:published_time" content={publishedDate.toISOString()} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Alternate languages -->
    {Object.keys(languages).map((code) => (
      <link rel="alternate" hreflang={code} href={`https://viniciusbuscacio.blog${getLocalizedPath(currentPath, code as Lang)}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`https://viniciusbuscacio.blog/pt${currentPath}`} />

    <!-- Google Analytics 4 -->
    {GA_ID !== 'G-XXXXXXXXXX' && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline define:vars={{ GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA_ID);
        </script>
      </>
    )}

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(
      type === 'article' ? {
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "author": { "@type": "Person", "name": "Vinicius Buscacio" },
        "datePublished": publishedDate?.toISOString(),
        "image": ogImage,
        "url": canonicalUrl,
      } : {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Vinicius Buscacio",
        "url": "https://viniciusbuscacio.blog",
        "description": description,
        "author": { "@type": "Person", "name": "Vinicius Buscacio" },
      }
    )} />

    <script is:inline>
      if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="bg-white dark:bg-bg-dark text-gray-900 dark:text-text-dark min-h-screen flex flex-col transition-colors">
    <!-- Header -->
    <header class="border-b border-gray-200 dark:border-border-dark sticky top-0 bg-white/80 dark:bg-bg-dark/80 backdrop-blur-sm z-50">
      <nav class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href={getLocalizedPath('/', lang)} class="logo-brand text-xl font-bold text-black dark:text-gh-blue hover:opacity-80 transition">
          viniciusbuscacio.blog
        </a>
        
        <div class="flex items-center gap-6">
          <!-- Desktop nav -->
          <div class="hidden sm:flex items-center gap-4 text-base">
            <a href={getLocalizedPath('/', lang)} class="text-gray-600 dark:text-gh-muted hover:text-black dark:hover:text-text-dark transition">{t('nav.home')}</a>
            <a href={getLocalizedPath('/about', lang)} class="text-gray-600 dark:text-gh-muted hover:text-black dark:hover:text-text-dark transition">{t('nav.about')}</a>
          </div>

          <!-- Mobile hamburger -->
          <button
            id="mobile-menu-btn"
            class="sm:hidden p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gh-surface transition"
            aria-label="Menu"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>

          <!-- Social icons -->
          <div class="header-social hidden sm:flex items-center gap-2">
            <a href="https://github.com/viniciusbuscacio" target="_blank" rel="noopener" title="GitHub" class="text-gray-500 dark:text-gh-muted hover:text-black dark:hover:text-text-dark transition">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            </a>
            <a href="https://www.linkedin.com/in/viniciusbuscacio" target="_blank" rel="noopener" title="LinkedIn" class="text-gray-500 dark:text-gh-muted hover:text-black dark:hover:text-text-dark transition">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          </div>

          <!-- Language Switcher -->
          <div class="flex items-center gap-1 text-sm">
            {Object.entries(languages).map(([code, name]) => (
              <a
                href={getLocalizedPath(currentPath, code as Lang)}
                class:list={[
                  'px-2 py-1 rounded transition',
                  code === lang
                    ? 'bg-black text-white dark:bg-gh-blue dark:text-bg-dark'
                    : 'text-gray-500 hover:text-black dark:hover:text-text-dark',
                ]}
              >
                {code.toUpperCase()}
              </a>
            ))}
          </div>

          <!-- Theme Toggle -->
          <button
            id="theme-toggle"
            class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gh-surface transition"
            aria-label="Toggle dark mode"
          >
            <svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" />
            </svg>
            <svg class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20">
              <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
            </svg>
          </button>
        </div>
      </nav>

      <!-- Mobile menu (hidden by default) -->
      <div id="mobile-menu" class="hidden sm:hidden border-t border-gray-200 dark:border-border-dark bg-white/95 dark:bg-bg-dark/95 backdrop-blur-sm">
        <div class="max-w-5xl mx-auto px-4 py-3 flex flex-col gap-3 text-base">
          <a href={getLocalizedPath('/', lang)} class="text-gray-600 dark:text-gh-muted hover:text-black dark:hover:text-text-dark transition py-1">{t('nav.home')}</a>
          <a href={getLocalizedPath('/about', lang)} class="text-gray-600 dark:text-gh-muted hover:text-black dark:hover:text-text-dark transition py-1">{t('nav.about')}</a>
        </div>
      </div>
    </header>

    <!-- Main -->
    <main class="flex-1 max-w-5xl mx-auto px-4 py-8 w-full">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 dark:border-border-dark py-6">
      <div class="max-w-5xl mx-auto px-4 text-center text-gray-500 dark:text-gh-muted">
        <div class="footer-compact">
          <a href={getLocalizedPath('/about', lang)} class="hover:text-black dark:hover:text-text-dark transition">{t('nav.about')}</a>
          <span class="sep">·</span>
          <a href="https://github.com/viniciusbuscacio" class="hover:text-black dark:hover:text-text-dark transition" target="_blank" rel="noopener">GitHub</a>
          <span class="sep">·</span>
          <a href="https://www.linkedin.com/in/viniciusbuscacio" class="hover:text-black dark:hover:text-text-dark transition" target="_blank" rel="noopener">LinkedIn</a>
          <span class="sep">·</span>
          <span>© 2026 Vinicius Buscacio</span>
        </div>
        <p class="mt-1" style="font-size:0.75rem;opacity:0.4">{t('footer.madeWith')} <a href="https://astro.build" class="text-black dark:text-gh-blue hover:underline">Astro</a> {t('footer.by')}</p>
      </div>
    </footer>

    <script is:inline>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });

      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        const menu = document.getElementById('mobile-menu');
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
